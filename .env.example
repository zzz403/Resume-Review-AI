# ── LLM provider ────────────────────────────────────────────────
# Which model backend to use for text tasks: anthropic | deepseek | gemini | openai
TEXT_LLM_PROVIDER=anthropic

# Which model backend to use for image/PDF page reading: anthropic | gemini | openai
VISION_LLM_PROVIDER=openai

# Fill in the key for whichever provider you selected above.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional per-provider model overrides (defaults shown):
#   ANTHROPIC_MODEL=claude-haiku-4-5-20251001
#   DEEPSEEK_MODEL=deepseek-chat
#   GEMINI_MODEL=gemini-2.0-flash
#   OPENAI_MODEL=gpt-5.5

# ── Other services ──────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_URL=http://localhost:8000
